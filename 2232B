#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define f first
#define s second  
#define int long long

signed main() {

    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while(t--) {

        int n;
        cin >> n;

        vector<int> a(n);
        for(int i = 0; i < n; i++) {

            cin >> a[i];

        }

        vector<int> ans;
        ans.push_back(a[0]);
        int curSum = a[0];
        for(int i = 1; i < n; i++) {

            curSum += a[i];
            ans.push_back(min(ans[i - 1], curSum / (i + 1)));

        }

        for(int i = 0; i < n; i++) {

            cout << ans[i] << " ";

        }
        cout << endl;

    }

}
